{
  "name": "conversionlint",
  "version": "0.1.0",
  "description": "Conversion quality scanner for websites that are supposed to convert.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "conversionlint": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "action.yml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write .",
    "scan": "tsx src/cli.ts"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "cheerio": "^1.1.2",
    "commander": "^14.0.1",
    "picocolors": "^1.1.1",
    "playwright": "^1.53.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
