{
  "name": "conversionlint",
  "version": "0.1.0",
  "description": "Conversion quality scanner for websites that are supposed to convert.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "conversionlint": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write .",
    "scan": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "cheerio": "^1.1.0",
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "playwright": "^1.54.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
